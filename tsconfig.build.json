{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "target": "ES2023",
    "jsx": "react-jsx",
    "outDir": "build",
    "rootDir": ".",
    "noEmitOnError": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2023", "DOM"],
    "rewriteRelativeImportExtensions": true
  }
}
